# Copy this file to .env before running locally.
# Run everything from the project root inside WSL2, for example: ~/projects/controldiff

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Local-first defaults keep the project runnable without Docker.
DATABASE_URL=sqlite+pysqlite:///artifacts/controldiff.db
QDRANT_MODE=local
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_LOCAL_PATH=artifacts/qdrant
QDRANT_COLLECTION=controldiff_controls

REDIS_URL=redis://localhost:6379/0
USE_BACKGROUND_JOBS=false

# Optional LLM provider settings.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional tracing.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Data locations relative to project root.
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
SYNTHETIC_DATA_DIR=data/synthetic
GOLDEN_DATA_DIR=data/goldens
